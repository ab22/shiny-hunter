LLVM_PREFIX="$(brew --prefix llvm)"
PATH_prepend "$LLVM_PREFIX/bin"
export LDFLAGS="-L${LLVM_PREFIX}/lib"
export CPPFLAGS="-I${LLVM_PREFIX}/include"
export LD_LIBRARY_PATH="/opt/homebrew/lib${LD_LIBRARY_PATH:+:${LD_LIBRARY_PATH}}"
export DYLD_FALLBACK_LIBRARY_PATH="/opt/homebrew/opt/llvm/lib${DYLD_FALLBACK_LIBRARY_PATH:+:${DYLD_FALLBACK_LIBRARY_PATH}}"
